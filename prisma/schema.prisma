generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProfileStep {
  COMPANY
  KYC
  COMPLETED
}

model User {
  id          Int         @id @default(autoincrement())
  username    String
  mobile_no   String      @unique
  password    String
  profileStep ProfileStep @default(COMPANY)

  company     Company?
  kyc         Kyc?

  createdAt   DateTime    @default(now())
}

model Company {
  id           Int    @id @default(autoincrement())
  company_name String
  salary       Int

  userId       Int    @unique
  user         User   @relation(fields: [userId], references: [id])
}

model Kyc {
  id           Int    @id @default(autoincrement())
  adharcard_no String @unique
  pancard_no   String @unique

  userId       Int    @unique
  user         User   @relation(fields: [userId], references: [id])
}
